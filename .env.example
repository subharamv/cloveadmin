# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Google Maps Platform: Required for map features.
# To get an API key: https://console.cloud.google.com/google/maps-apis/start?utm_campaign=gmp-code-assist-ais
GOOGLE_MAPS_PLATFORM_KEY="YOUR_API_KEY"

# MongoDB connection string for the backend dashboard logs and admin settings
MONGODB_URI="mongodb://localhost:27017/facility_management"

# JWT secret key for signature signing and verification on authenticated API routes
JWT_SECRET="super-secret-key-change-in-production"

# Google Sheets-backed login: spreadsheet used as the user store, and the
# service account key file used to read/write it (share the sheet with the
# service account's client_email as an Editor).
GOOGLE_SHEETS_SPREADSHEET_ID="YOUR_SPREADSHEET_ID"
GOOGLE_SHEETS_SHEET_NAME="LoginAccounts"
GOOGLE_APPLICATION_CREDENTIALS="./service-account-key.json"

# Credentials for the default admin user seeded into the sheet on server start
ADMIN_SEED_EMAIL="admin@example.com"
ADMIN_SEED_PASSWORD="change-me"

# Credentials for the default security guard account (role=Security), used to
# log in at /visitor to register visitor entries/exits
SECURITY_SEED_EMAIL="security@example.com"
SECURITY_SEED_PASSWORD="change-me"

# Visitor tracking: tab names within the same spreadsheet, and the Drive
# Shared Drive (or folder) ID where visitor photos/documents are stored.
# The service account's client_email must be a member of this Shared Drive.
GOOGLE_SHEETS_VISITORS_SHEET_NAME="Visitors"
GOOGLE_SHEETS_VISITOR_LOGS_SHEET_NAME="VisitorLogs"
GOOGLE_DRIVE_ROOT_FOLDER_ID="YOUR_SHARED_DRIVE_OR_FOLDER_ID"

